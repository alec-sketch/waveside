generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Technology {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  manufacturer String
  description String
  mechanism   String   // pneumatic, hydraulic, mechanical, foil, etc.
  mechanismDescription String

  // Specs
  wavesPerHour    Int
  maxWaveHeight   Float    // in feet
  minAcreage      Float
  maxAcreage      Float
  skillLevelMin   String   // beginner, intermediate, advanced
  skillLevelMax   String

  // Cost ranges (USD)
  costMin         Float
  costMax         Float
  annualOperating Float    // estimated annual operating cost

  // Additional
  pros            String[] // array of pros
  cons            String[] // array of cons
  imageUrl        String?
  featured        Boolean  @default(false)

  estimates       Estimate[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model State {
  id              String   @id @default(cuid())
  code            String   @unique  // e.g., "CA"
  name            String   @unique  // e.g., "California"
  region          String   // e.g., "West", "Southeast"

  // Cost modifiers
  laborCostMultiplier    Float @default(1.0)
  permitCostMultiplier   Float @default(1.0)
  landCostPerAcre        Float // avg commercial land cost

  // Regulations
  waterRegulationLevel   String @default("moderate") // low, moderate, high
  environmentalReview    Boolean @default(false)

  estimates              Estimate[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Estimate {
  id              String   @id @default(cuid())

  // Inputs
  technologyId    String
  technology      Technology @relation(fields: [technologyId], references: [id])
  stateId         String
  state           State      @relation(fields: [stateId], references: [id])
  acreage         Float
  propertyType    String     // residential, commercial
  indoor          Boolean    @default(false)

  // Calculated results
  technologyCost      Float
  constructionCost    Float
  landCost            Float
  permitCost          Float
  infrastructureCost  Float
  annualOperatingCost Float
  totalCost           Float
  fitScore            Int      // 0-100

  createdAt           DateTime @default(now())

  @@index([technologyId])
  @@index([stateId])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String?
  createdAt DateTime @default(now())
}
